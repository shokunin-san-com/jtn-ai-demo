{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb",
        "runtime": "python3.12",
        "includeFiles": "templates/**/*.xlsx,lib/**/*.py,requirements.txt"
      }
    }
  ],
  "functions": {
    "api/*.py": {
      "maxDuration": 10,
      "memory": 1024
    }
  }
}
